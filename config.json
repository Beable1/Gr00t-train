{
    "type": "groot",
    "n_obs_steps": 1,
    "input_features": {
        "observation.state": {
            "type": "STATE",
            "shape": [
                17
            ]
        },
        "observation.images.rgb": {
            "type": "VISUAL",
            "shape": [
                3,
                360,
                640
            ]
        }
    },
    "output_features": {
        "action": {
            "type": "ACTION",
            "shape": [
                17
            ]
        }
    },
    "device": "cuda",
    "use_amp": false,
    "use_peft": false,
    "push_to_hub": false,
    "repo_id": null,
    "private": null,
    "tags": null,
    "license": null,
    "pretrained_path": null,
    "chunk_size": 50,
    "n_action_steps": 50,
    "max_state_dim": 64,
    "max_action_dim": 32,
    "normalization_mapping": {
        "VISUAL": "IDENTITY",
        "STATE": "MEAN_STD",
        "ACTION": "MEAN_STD"
    },
    "image_size": [
        224,
        224
    ],
    "base_model_path": "nvidia/GR00T-N1.5-3B",
    "tokenizer_assets_repo": "lerobot/eagle2hg-processor-groot-n1p5",
    "embodiment_tag": "new_embodiment",
    "tune_llm": false,
    "tune_visual": false,
    "tune_projector": true,
