    "lora_full_model": false,
    "optimizer_lr": 0.0001,
    "optimizer_betas": [
        0.95,
        0.999
    ],
    "optimizer_eps": 1e-08,
    "optimizer_weight_decay": 1e-05,
    "warmup_ratio": 0.05,
    "use_bf16": true,
    "video_backend": "decord",
    "balance_dataset_weights": true,
    "balance_trajectory_weights": true,
    "dataset_paths": null,
    "output_dir": "./tmp/gr00t",
    "save_steps": 1000,
    "max_steps": 10000,
    "batch_size": 32,
    "dataloader_num_workers": 8,
    "report_to": "wandb",
    "resume": false
}